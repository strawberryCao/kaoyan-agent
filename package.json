{
  "name": "app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "preinstall": "node preinstall.js",
    "predist": "node scripts/check-desktop-runtime.js",
    "check:desktop": "node scripts/check-desktop-runtime.js",
    "test:desktop": "node --test tests/desktop_runtime.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strawberryCao/kaoyan-agent.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/strawberryCao/kaoyan-agent/issues"
  },
  "homepage": "https://github.com/strawberryCao/kaoyan-agent#readme",
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "productName": "Streamlit",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "index.js",
      "desktop_runtime.js"
    ],
    "extraResources": [
      {
        "from": "streamlit",
        "to": "streamlit",
        "filter": [
          "**/*",
          ".venv/**/*",
          ".python-runtime/**/*"
        ]
      }
    ]
  }
}
