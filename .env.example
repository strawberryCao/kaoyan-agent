# LLM service
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# Embedding service. Default target is SiliconFlow BAAI/bge-m3.
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_SECONDS=20

# Memory backends. SQLite remains the primary data store.
VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=data/chroma

GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
GRAPH_SYNC_RAW_EVENTS=false

# Optional local YOLO focus supervision.
YOLO_FOCUS_WEIGHTS_PATH=
YOLO_FOCUS_CAMERA_ID=0
YOLO_FOCUS_CONFIDENCE_THRESHOLD=0.5
YOLO_FOCUS_INFERENCE_FPS=3
